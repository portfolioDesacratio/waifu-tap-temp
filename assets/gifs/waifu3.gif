<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 500">
  <defs>
    <linearGradient id="hair" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#d0d0d0"/>
      <stop offset="100%" style="stop-color:#f0f0f0"/>
    </linearGradient>
    <linearGradient id="dress" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#9370db"/>
      <stop offset="100%" style="stop-color:#7b68ee"/>
    </linearGradient>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0f0a1a"/>
      <stop offset="100%" style="stop-color:#0a0f1f"/>
    </linearGradient>
    <radialGradient id="moon" cx="50%" cy="50%" r="50%">
      <stop offset="0%" style="stop-color:#e0b0ff" stop-opacity="0.15"/>
      <stop offset="100%" style="stop-color:#e0b0ff" stop-opacity="0"/>
    </radialGradient>
  </defs>
  <circle cx="200" cy="250" r="180" fill="url(#bg)" opacity="0.3"/>
  <circle cx="200" cy="250" r="160" fill="none" stroke="#9370db" stroke-width="1" opacity="0.1"/>
  <circle cx="200" cy="180" r="60" fill="url(#moon)"/>
  <!-- Crescent moon behind -->
  <circle cx="190" cy="170" r="20" fill="none" stroke="#e0b0ff" stroke-width="1" opacity="0.2"/>
  <circle cx="198" cy="167" r="16" fill="#0f0a1a"/>
  <ellipse cx="200" cy="220" rx="90" ry="110" fill="url(#hair)" opacity="0.8"/>
  <ellipse cx="200" cy="220" rx="65" ry="75" fill="#fce4ec"/>
  <!-- Closed eyes (sleepy/mysterious) -->
  <path d="M160,205 Q175,195 190,205" fill="none" stroke="#1a0f1a" stroke-width="2.5" stroke-linecap="round"/>
  <path d="M210,205 Q225,195 240,205" fill="none" stroke="#1a0f1a" stroke-width="2.5" stroke-linecap="round"/>
  <ellipse cx="165" cy="235" rx="12" ry="6" fill="#9370db" opacity="0.3"/>
  <ellipse cx="235" cy="235" rx="12" ry="6" fill="#9370db" opacity="0.3"/>
  <path d="M190,242 Q200,250 210,242" fill="none" stroke="#e57373" stroke-width="2" stroke-linecap="round"/>
  <path d="M140,200 Q135,150 160,120 Q180,100 200,110 Q220,100 240,120 Q265,150 260,200" fill="url(#hair)" opacity="0.9"/>
  <path d="M160,130 Q180,120 195,150 Q200,160 205,150 Q220,120 240,130 Q230,170 200,175 Q170,170 160,130Z" fill="url(#hair)"/>
  <!-- Long flowing side strands -->
  <path d="M140,180 Q125,230 130,280" fill="none" stroke="url(#hair)" stroke-width="8" stroke-linecap="round" opacity="0.6"/>
  <path d="M260,180 Q275,230 270,280" fill="none" stroke="url(#hair)" stroke-width="8" stroke-linecap="round" opacity="0.6"/>
  <!-- Star hair accessory -->
  <polygon points="145,170 148,162 151,170 158,170 153,175 155,183 148,178 141,183 143,175 138,170" fill="#e0b0ff" opacity="0.7"/>
  <polygon points="255,170 258,162 261,170 268,170 263,175 265,183 258,178 251,183 253,175 248,170" fill="#e0b0ff" opacity="0.7"/>
  <path d="M135,185 Q115,175 120,165 Q130,170 140,175Z" fill="#9370db"/>
  <path d="M265,185 Q285,175 280,165 Q270,170 260,175Z" fill="#9370db"/>
  <rect x="188" y="280" width="24" height="20" rx="5" fill="#fce4ec"/>
  <path d="M145,300 L255,300 L270,470 L130,470Z" fill="url(#dress)" opacity="0.9"/>
  <path d="M185,300 L200,330 L215,300Z" fill="#e0b0ff" opacity="0.2"/>
  <!-- Star on dress -->
  <polygon points="200,365 202,358 206,365 213,365 208,370 210,377 204,373 198,377 200,370 195,365" fill="#e0b0ff" opacity="0.5"/>
  <path d="M200,340 Q185,330 180,340 Q185,350 200,340Z" fill="#9370db"/>
  <path d="M200,340 Q215,330 220,340 Q215,350 200,340Z" fill="#9370db"/>
  <circle cx="200" cy="340" r="4" fill="#e0b0ff"/>
  <path d="M145,310 Q120,340 115,380" fill="none" stroke="url(#dress)" stroke-width="16" stroke-linecap="round"/>
  <path d="M255,310 Q280,340 285,380" fill="none" stroke="url(#dress)" stroke-width="16" stroke-linecap="round"/>
  <circle cx="115" cy="380" r="10" fill="#fce4ec"/>
  <circle cx="285" cy="380" r="10" fill="#fce4ec"/>
  <rect x="155" y="360" width="90" height="18" rx="9" fill="#9370db" opacity="0.2"/>
  <text x="200" y="374" text-anchor="middle" fill="#e0b0ff" font-size="12" font-family="serif">Юки</text>
  <circle cx="100" cy="150" r="3" fill="#ffd700" opacity="0.6">
    <animate attributeName="opacity" values="0.6;1;0.6" dur="2s" repeatCount="indefinite"/>
  </circle>
  <circle cx="300" cy="130" r="2" fill="#9370db" opacity="0.8">
    <animate attributeName="opacity" values="0.8;0.2;0.8" dur="1.5s" repeatCount="indefinite"/>
  </circle>
  <circle cx="320" cy="200" r="2.5" fill="#e0b0ff" opacity="0.5">
    <animate attributeName="opacity" values="0.5;1;0.5" dur="2.5s" repeatCount="indefinite"/>
  </circle>
  <circle cx="80" cy="230" r="2" fill="#ffd700" opacity="0.4">
    <animate attributeName="opacity" values="0.4;0.8;0.4" dur="1.8s" repeatCount="indefinite"/>
  </circle>
  <!-- Tiny stars -->
  <circle cx="330" cy="160" r="1.5" fill="#e0b0ff" opacity="0.4">
    <animate attributeName="opacity" values="0.4;0.9;0.4" dur="2.2s" repeatCount="indefinite"/>
  </circle>
  <circle cx="70" cy="190" r="1.5" fill="#e0b0ff" opacity="0.3">
    <animate attributeName="opacity" values="0.3;0.8;0.3" dur="2.8s" repeatCount="indefinite"/>
  </circle>
</svg>